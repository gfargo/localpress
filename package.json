{
  "name": "localpress",
  "version": "1.14.0",
  "description": "Local-compute WordPress media optimization. Your laptop, your library.",
  "license": "MIT",
  "author": "Griffen Fargo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gfargo/localpress.git"
  },
  "homepage": "https://github.com/gfargo/localpress",
  "bugs": {
    "url": "https://github.com/gfargo/localpress/issues"
  },
  "keywords": [
    "wordpress",
    "cli",
    "media",
    "image-optimization",
    "background-removal",
    "local-first",
    "rest-api",
    "mcp"
  ],
  "type": "module",
  "bin": {
    "localpress": "./src/cli/index.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "bun run scripts/build-tarball.ts",
    "build:all": "bun run scripts/build-tarball.ts --platform=darwin-arm64 && bun run scripts/build-tarball.ts --platform=darwin-x64 && bun run scripts/build-tarball.ts --platform=linux-arm64 && bun run scripts/build-tarball.ts --platform=linux-x64 && bun run scripts/build-tarball.ts --platform=windows-x64",
    "build:darwin-arm64": "bun run scripts/build-tarball.ts --platform=darwin-arm64",
    "build:darwin-x64": "bun run scripts/build-tarball.ts --platform=darwin-x64",
    "build:linux-arm64": "bun run scripts/build-tarball.ts --platform=linux-arm64",
    "build:linux-x64": "bun run scripts/build-tarball.ts --platform=linux-x64",
    "build:windows-x64": "bun run scripts/build-tarball.ts --platform=windows-x64",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:tarball": "bun test test/tarball/",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@jsquash/avif": "^2.1.1",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/png": "^3.1.1",
    "@jsquash/resize": "^2.1.1",
    "@jsquash/webp": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "onnxruntime-node": "^1.22.0",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "sharp": "^0.33.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/react": "^18.3.12",
    "bun-types": "^1.1.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.6.3"
  }
}
